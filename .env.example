# Copy to `.env` and fill in. Never commit real values.

# --- Required for Vercel static deploy (Supabase-only) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side Supabase (audit API + profile writes). Never expose to the browser.
# Before first audit save: run supabase/migrations/RUN_AUDIT_MIGRATIONS_ONLY.sql in Supabase SQL Editor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM for audit engine (required when mock is off)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Make.com Phase 1 audit trigger (homepage → onboarding)
MAKE_WEBHOOK_URL=https://hook.us2.make.com/p3rc76b5kdbvzgde8h5cmaec4jw4k74y
MAKE_WEBHOOK_SECRET=
# auto | make | forge | mock (mock also via AUDIT_MOCK=true)
AUDIT_PROVIDER=auto

# Dummy audit in dev (no scrape/API). Set false when cloud API is ready.
VITE_AUDIT_MOCK=true
AUDIT_MOCK=true

# --- Optional branding / integrations ---
VITE_APP_ID=
VITE_APP_TITLE=
VITE_APP_LOGO=
VITE_OAUTH_PORTAL_URL=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional: legacy Express API for advanced dashboard features (not required for auth)
# VITE_API_ORIGIN=https://api.yourdomain.com

# --- Local Express dev only (not used on Vercel static) ---
NODE_ENV=development
PORT=3000
DATABASE_URL=
JWT_SECRET=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
